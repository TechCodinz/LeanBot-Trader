# Environment variables for LeanBot-Trader
# Copy this file to .env and fill in your API credentials

# Exchange API Credentials
EXCHANGE_API_KEY=your_api_key_here
EXCHANGE_SECRET=your_secret_here
EXCHANGE_PASSPHRASE=your_passphrase_here  # For some exchanges like Coinbase Pro

# Optional: Sandbox/Testnet credentials
SANDBOX_API_KEY=your_sandbox_api_key
SANDBOX_SECRET=your_sandbox_secret

# Database (optional)
DATABASE_URL=sqlite:///leanbot.db

# Notification settings
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=

# Email settings
SMTP_SERVER=
SMTP_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
TO_EMAIL=

# API rate limits and timeouts
API_TIMEOUT=30
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW=60